# ============================================================
# 🔗 Shared
# ============================================================

# ✅ required - Public URL of the API server.
VITE_SERVER_URL="http://localhost:5000/server"

# ✅ required - Public URL of the web app.
VITE_WEB_URL="http://localhost:3000"

# ✅ required - PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/tsu-stack"

# ✅ required - Secret key for Better Auth. Generate with: vp run auth:secret
BETTER_AUTH_SECRET=

# ============================================================
# 🌍 Web
# ============================================================

# ⚙️ optional - Base URL for imgproxy. Leave empty to disable.
VITE_IMGPROXY_URL=""

# ⚙️ optional - imgproxy signature path segment. Defaults to "_" for unsigned imgproxy URLs.
# Use "insecure" or a precomputed signature string if your imgproxy setup requires it.
VITE_IMGPROXY_SIGNATURE="_"

# ============================================================
# 🖥️ Server
# ============================================================

# ⚙️ optional - Expose the OpenAPI /docs endpoint.
ENABLE_OPEN_API_DOCS="false"

# ============================================================
# 🔨 Build
# ============================================================

# ⚙️ optional - Git commit SHA injected at build time.
SOURCE_COMMIT=""
# Used only by `vp run --filter @tsu-stack/server seed:platform-admin`.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
